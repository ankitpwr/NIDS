# ============================================================================
# ML SERVICE (.env)
# ============================================================================
# Python Flask service for machine learning predictions
# Location: ml-service/.env
# Port: 3002
#
# This service:
# - Loads batch-trained ML artifacts (preprocessor, autoencoder, ORC, classifier)
# - Accepts network flow features via POST /predict
# - Returns attack/normal predictions
# ============================================================================

# ─── ARTIFACT PATHS ─────────────────────────────────────────────────────────
# Directory containing all trained model artifacts
ML_BASE_DIR=.
ML_ARTIFACTS_DIR=./artifacts

# Individual artifact file paths (relative to ML_BASE_DIR)
# These are looked up inside ML_ARTIFACTS_DIR subdirectory
ML_PREPROCESSOR_PATH=./artifacts/preprocessor.pkl
ML_AE_PATH=./artifacts/ae.pt
ML_ORC_PATH=./artifacts/orc.npz
ML_RF_PATH=./artifacts/rf.pkl
ML_METADATA_PATH=./artifacts/training_metadata.json

# ─── SERVER CONFIGURATION ────────────────────────────────────────────────────
# Host to bind to (0.0.0.0 = listen on all interfaces)
ML_HOST=0.0.0.0

# Port to listen on
ML_PORT=3002

# ─── DEBUG & THRESHOLD ──────────────────────────────────────────────────────
# Enable debug mode for verbose logging
ML_DEBUG=false

# Default attack detection threshold (0.0 to 1.0)
# Predictions with probability >= this threshold are classified as ATTACK
# This value is overridden by optimized_attack_threshold from training_metadata.json
ML_ATTACK_THRESHOLD=0.5

# ─── OPTIONAL: DATABASE (for future integration) ────────────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/nids_ml
