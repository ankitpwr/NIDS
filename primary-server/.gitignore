# ============================================================================
# PRIMARY SERVER .gitignore
# ============================================================================
# Node.js Express backend server

# ─── Environment & Configuration ────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Node.js ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ─── Build Output ──────────────────────────────────────────────────────────
dist/
build/
out/
.next/

# ─── Package Manager Files ─────────────────────────────────────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── IDE & Editors ─────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ─── Logs & Debugging ──────────────────────────────────────────────────────
*.log
logs/
.debug

# ─── OS Files ──────────────────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
.TemporaryItems
__MACOSX/
Thumbs.db
ehthumbs.db

# ─── Testing & Coverage ───────────────────────────────────────────────────
coverage/
.nyc_output/
junit.xml

# ─── Database (for future Prisma integration) ──────────────────────────────
.env.production.local
prisma/.env

# ─── Temporary Files ──────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.orig

# ─── In-memory Database ───────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
