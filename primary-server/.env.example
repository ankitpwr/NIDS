# ============================================================================
# PRIMARY SERVER (.env)
# ============================================================================
# Node.js Express backend server
# Location: primary-server/.env
# Port: 3000
#
# This service:
# - Receives network flow data from the agent
# - Forwards to ML service for predictions
# - Stores attack logs in memory (or database when Prisma is integrated)
# - Provides API endpoints for the frontend dashboard
# ============================================================================

# ─── SERVER CONFIGURATION ────────────────────────────────────────────────────
# Port to listen on
PORT=3000

# Server host (0.0.0.0 = listen on all interfaces)
# HOST=0.0.0.0  # Uncomment if needed

# ─── ML SERVICE INTEGRATION ─────────────────────────────────────────────────
# Full URL to the ML service prediction endpoint
# Used to send network features for classification
ML_SERVICE_URL=http://localhost:3002/predict

# ML service health check endpoint
# ML_HEALTH_URL=http://localhost:3002/health  # Optional

# ─── DATABASE (future Prisma integration) ───────────────────────────────────
# When migrating from in-memory to Prisma + PostgreSQL, uncomment:
# DATABASE_URL=postgresql://user:password@localhost:5432/nids

# ─── LOGGING & DEBUG ────────────────────────────────────────────────────────
# Enable debug mode
DEBUG=false

# Log level (info, warn, error, debug)
LOG_LEVEL=info

# ─── MONITORING ─────────────────────────────────────────────────────────────
# Maximum number of flows to keep in memory
# When exceeded, oldest flows are discarded
MAX_LOG_SIZE=10000
