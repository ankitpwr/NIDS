# ============================================================================
# TEST SERVER (.env)
# ============================================================================
# Python Flask server simulating a real application under attack testing
# Location: test-server/.env
# Port: 8080
#
# This service:
# - Hosts vulnerable endpoints that can be attacked
# - Has NO knowledge of the agent, ML service, or NIDS system
# - Serves as the target for network traffic analysis
# - Provides endpoints for agent to monitor
# ============================================================================

# ─── SERVER CONFIGURATION ────────────────────────────────────────────────────
# Port to listen on
TEST_SERVER_PORT=8080

# Host to bind to (0.0.0.0 = all interfaces)
TEST_SERVER_HOST=0.0.0.0

# ─── ENDPOINT CONFIGURATION ─────────────────────────────────────────────────
# Endpoints exposed by test server:
# - GET  /api/v1/google/auth    → Target for DDoS/brute force attacks
# - GET  /api/v1/user           → Standard API endpoint
# - GET  /api/v1/data           → Standard API endpoint
# - GET  /health                → Health check endpoint

# Response delay (milliseconds) - simulates processing time
RESPONSE_DELAY_MS=10

# ─── LOGGING ────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
