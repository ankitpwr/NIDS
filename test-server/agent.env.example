# ============================================================================
# AGENT (.env) - Network Packet Sniffer
# ============================================================================
# Python Scapy-based packet sniffer agent
# Location: test-server/.env (or standalone location)
# No fixed port - runs as background process
#
# This service:
# - Captures network packets on specified interface/port
# - Extracts network flow features
# - Sends flows to backend for ML prediction
# - Monitors localhost for attack patterns (or LAN if configured)
# ============================================================================

# ─── TARGET CONFIGURATION ────────────────────────────────────────────────────
# Port to sniff for (test server listens on 8080)
TARGET_PORT=8080

# Network interface to sniff on
# Leave empty for auto-detection of LAN interface
# Windows loopback: \Device\NPF_Loopback
# Windows WiFi/LAN: auto-detected or use specific interface name
SNIFF_INTERFACE=

# ─── FLOW TIMING ─────────────────────────────────────────────────────────────
# Timeout for flow inactivity (seconds)
# Flows are sent to backend after this period of inactivity
FLOW_TIMEOUT=1

# Maximum packets per flow before sending
# Flows are sent after reaching this packet count
MAX_FLOW_PKTS=50

# Statistical window size (packets)
WINDOW_SIZE=20

# ─── BACKEND INTEGRATION ─────────────────────────────────────────────────────
# Full URL to backend ingestion endpoint
# Agent POSTs captured flows to this URL
AGENT_BACKEND_URL=http://localhost:3000/api/v1/ingest

# Recent window for statistic calculations (seconds)
RECENT_WINDOW=1

# ─── DEDUPLICATION ─────────────────────────────────────────────────────────────
# TTL for duplicate packet detection (seconds)
DEDUP_TTL=0.5

# ─── QUEUE & PERFORMANCE ────────────────────────────────────────────────────
# Maximum packet queue size
# Packets are dropped if queue exceeds this size
PACKET_QUEUE_SIZE=10000

# ─── DEBUG & LOGGING ────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ─── PERMISSIONS ────────────────────────────────────────────────────────────
# NOTE: Agent MUST run with Administrator/root privileges to sniff packets
# On Windows: Run CMD/PowerShell as Administrator
# On Linux: Use sudo or add user to packet capture group
