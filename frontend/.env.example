# ============================================================================
# FRONTEND DASHBOARD (.env)
# ============================================================================
# Streamlit Python web dashboard
# Location: frontend/.env
# Port: 8501 (default Streamlit port, can be customized)
#
# This service:
# - Displays live network intrusion detection dashboard
# - Polls the backend for attack data, statistics, and health status
# - Visualizes network flows with interactive charts
# ============================================================================

# ─── BACKEND API CONFIGURATION ──────────────────────────────────────────────
# Full URL to the primary backend server
# Used to fetch attacks, statistics, and health data
BACKEND_URL=http://localhost:3000

# ─── DASHBOARD REFRESH SETTINGS ─────────────────────────────────────────────
# Polling interval (seconds) for backend updates
# Smaller values = more responsive dashboard, higher server load
REFRESH_SEC=2

# Maximum number of data points to retain in time-series charts
# Older data points are dropped when limit is exceeded
MAX_HISTORY=60

# ─── DISPLAY SETTINGS ──────────────────────────────────────────────────────
# Dashboard page title
# (Streamlit configuration - can also be set in streamlit config.toml)
# STREAMLIT_PAGE_TITLE=NIDS Dashboard

# ─── NETWORK SETTINGS ──────────────────────────────────────────────────────
# API request timeout (seconds)
API_TIMEOUT=5

# Number of most recent records to display in alert table
MAX_RECORDS_DISPLAY=100

# ─── DEBUG & LOGGING ────────────────────────────────────────────────────────
# Enable debug mode for verbose logging
DEBUG=false

# Log level
LOG_LEVEL=INFO
