# ============================================================================
# NIDS1 ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env in the root directory or the appropriate service
# directory, then update values according to your deployment environment.
#
# Each service (frontend, ml-service, primary-server, test-server) uses a
# subset of these variables. See service-specific .env files for details.
# ============================================================================

# ============================================================================
# PRIMARY SERVER (Node.js) - port 3000
# ============================================================================
# Configuration for the primary backend server

# ML Service URL for predictions
ML_SERVICE_URL=http://localhost:3002/predict

# Server port
PORT=3000

# (Optional) Database configuration for future Prisma + PostgreSQL integration
# DATABASE_URL=postgresql://user:password@localhost:5432/nids

# ============================================================================
# ML SERVICE (Python Flask) - port 3002
# ============================================================================
# Configuration for the machine learning service

# Base directory for the ML service
ML_BASE_DIR=.

# Artifacts directory containing trained models
ML_ARTIFACTS_DIR=./artifacts

# Paths to model artifacts
ML_PREPROCESSOR_PATH=./artifacts/preprocessor.pkl
ML_AE_PATH=./artifacts/ae.pt
ML_ORC_PATH=./artifacts/orc.npz
ML_RF_PATH=./artifacts/rf.pkl
ML_METADATA_PATH=./artifacts/training_metadata.json

# Server configuration
ML_HOST=0.0.0.0
ML_PORT=3002

# Debug mode (true/false)
ML_DEBUG=false

# Default attack detection threshold (0.0 - 1.0)
# This is overridden by the optimized threshold from training_metadata.json if available
ML_ATTACK_THRESHOLD=0.5

# ============================================================================
# FRONTEND (Streamlit Python) - port 8501 (default)
# ============================================================================
# Configuration for the Streamlit dashboard

# Backend API URL
BACKEND_URL=http://localhost:3000

# Refresh interval (seconds) for polling backend
REFRESH_SEC=2

# Maximum number of data points to keep in time-series charts
MAX_HISTORY=60

# ============================================================================
# TEST SERVER (Python Flask) - port 8080
# ============================================================================
# Configuration for the test/victim server

# Server port
TEST_SERVER_PORT=8080

# Server host
TEST_SERVER_HOST=0.0.0.0

# ============================================================================
# AGENT (Python Packet Sniffer) - Standalone process
# ============================================================================
# Configuration for the network packet sniffer agent

# Target server port to sniff
TARGET_PORT=8080

# Backend URL to send captured flows
AGENT_BACKEND_URL=http://localhost:3000/api/v1/ingest

# Flow timeout (seconds)
FLOW_TIMEOUT=1

# Maximum number of packets per flow
MAX_FLOW_PKTS=50

# Window size for statistic calculations
WINDOW_SIZE=20

# Network interface to sniff on (auto-detected if not set)
# For loopback (local testing): \Device\NPF_Loopback (Windows)
# For WiFi/LAN: auto-detected from available interfaces
SNIFF_INTERFACE=

# ============================================================================
# DEVELOPMENT / DEBUG FLAGS
# ============================================================================

# Enable verbose logging across services
DEBUG=false

# Log level (INFO, DEBUG, WARNING, ERROR)
LOG_LEVEL=INFO
